rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — anyone can read, owner can write anything,
    // any authenticated user may update only the social-graph fields
    // (so friend requests/accepts/declines work across users)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['friendRequestsIn', 'friendRequestsOut', 'friends', 'updatedAt']);
    }

    // Leaderboards — anyone can read, only owner can write their own entry
    match /xp_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /scholar_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /consistency_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Username / display name uniqueness checks
    match /usernames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /displayNames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Push notifications — recipient can read their own, any auth user can write
    match /encouragements/{uid}/messages/{msgId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null;
    }

    // Studies — any authenticated user can read all studies (for the community board).
    // Only the creator can create a study (creatorUid must match auth uid).
    // Any collaborator can update the study document (session timestamps, rhema positions, etc.).
    // Only the creator can delete.
    match /studies/{studyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid
        && request.auth.uid in request.resource.data.collaboratorUids;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.collaboratorUids ||
        request.auth.uid == resource.data.creatorUid
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorUid;
    }

    // Study subcollections — any collaborator can read/write notes, saved verses, and word log
    match /studies/{studyId}/notes/{noteId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }
    match /studies/{studyId}/savedVerses/{verseId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }
    match /studies/{studyId}/wordLog/{wordId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }

  }
}
