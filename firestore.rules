rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — anyone can read, owner can write anything,
    // any authenticated user may update only the social-graph fields
    // (so friend requests/accepts/declines work across users)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['friendRequestsIn', 'friendRequestsOut', 'friends', 'updatedAt']);
    }

    // Leaderboards — anyone can read, only owner can write their own entry
    match /xp_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /scholar_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /consistency_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Username / display name uniqueness checks
    match /usernames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /displayNames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Push notifications — recipient can read their own, any auth user can write
    match /encouragements/{uid}/messages/{msgId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null;
    }

    // Community posts — visible only to the post audience.
    // Authors can create their own posts, audience members can react,
    // and authors can soft-delete their own posts.
    match /communityPosts/{postId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.audienceUids;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.auth.uid in request.resource.data.audienceUids;
      allow update: if request.auth != null && (
        // Friends in the audience can update lightweight social fields.
        (request.auth.uid in resource.data.audienceUids &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['reactions', 'prayers', 'commentCount'])) ||
        // Author can soft-delete the post.
        (request.auth.uid == resource.data.authorUid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['isActive', 'deletedAt']))
      );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.authorUid;
    }

    match /communityPosts/{postId}/comments/{commentId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/communityPosts/$(postId)).data.audienceUids;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/communityPosts/$(postId)).data.audienceUids;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.authorUid;
    }

    // Studies — any authenticated user can read all studies (for the community board).
    // Only the creator can create a study (creatorUid must match auth uid).
    // Any collaborator can update the study document (session timestamps, rhema positions, etc.).
    // Only the creator can delete.
    match /studies/{studyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid
        && request.auth.uid in request.resource.data.collaboratorUids;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.collaboratorUids ||
        request.auth.uid == resource.data.creatorUid ||
        // Any auth user can add themselves to pendingCollaboratorUids (collab request)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingCollaboratorUids']) &&
         request.auth.uid in request.resource.data.pendingCollaboratorUids) ||
        // Invitee can accept their own invite (moves self from pending → collaborator)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collaboratorUids', 'pendingCollaboratorUids']) &&
         request.auth.uid in resource.data.pendingCollaboratorUids &&
         !(request.auth.uid in resource.data.collaboratorUids))
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorUid;
    }

    // Study subcollections — any collaborator can read/write notes, saved verses, and word log
    match /studies/{studyId}/notes/{noteId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }
    match /studies/{studyId}/savedVerses/{verseId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }
    match /studies/{studyId}/wordLog/{wordId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }
    match /studies/{studyId}/trails/{trailId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }
    match /studies/{studyId}/entries/{entryId} {
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
      allow write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/studies/$(studyId)).data.collaboratorUids;
    }

  }
}
