rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — anyone can read, only owner can write
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Leaderboards — anyone can read, only owner can write their own entry
    match /xp_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /scholar_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /consistency_board/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Username / display name uniqueness checks
    match /usernames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /displayNames/{name} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Push notifications — recipient can read their own, any auth user can write
    match /encouragements/{uid}/messages/{msgId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null;
    }

    // Community Study Board — any auth user can read/write studies and all subcollections
    match /community_studies/{studyId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /contributions/{contribId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /polls/{pollId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /checkins/{checkinId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /prayers/{prayerId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /plan/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
